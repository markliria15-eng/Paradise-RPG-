[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://client/scripts/mmo_launcher.gd" id="1_launcher"]

[node name="MMOLauncher" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_launcher")

[node name="Root" type="PanelContainer" parent="."]
layout_mode = 1
offset_left = 260.0
offset_top = 56.0
offset_right = 1020.0
offset_bottom = 660.0

[node name="VBox" type="VBoxContainer" parent="Root"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Title" type="Label" parent="Root/VBox"]
layout_mode = 2
text = "Paradise RPG"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 24

[node name="Status" type="Label" parent="Root"]
layout_mode = 2
offset_left = 24.0
offset_top = 560.0
offset_right = 730.0
offset_bottom = 592.0
text = "Aguardando login..."
theme_override_colors/font_color = Color(0.95, 0.95, 0.95, 1)

[node name="Form" type="GridContainer" parent="Root"]
layout_mode = 2
offset_left = 28.0
offset_top = 64.0
offset_right = 732.0
offset_bottom = 540.0
columns = 2
theme_override_constants/h_separation = 12
theme_override_constants/v_separation = 8

[node name="UsernameLabel" type="Label" parent="Root/Form"]
layout_mode = 2
text = "Username"

[node name="Username" type="LineEdit" parent="Root/Form"]
layout_mode = 2
placeholder_text = "nome da conta"

[node name="EmailLabel" type="Label" parent="Root/Form"]
layout_mode = 2
text = "E-mail"

[node name="Email" type="LineEdit" parent="Root/Form"]
layout_mode = 2
placeholder_text = "email@exemplo.com"

[node name="PasswordLabel" type="Label" parent="Root/Form"]
layout_mode = 2
text = "Senha"

[node name="Password" type="LineEdit" parent="Root/Form"]
layout_mode = 2
secret = true
placeholder_text = "senha"

[node name="CharacterLabel" type="Label" parent="Root/Form"]
layout_mode = 2
text = "Personagem (registro)"

[node name="Character" type="LineEdit" parent="Root/Form"]
layout_mode = 2
placeholder_text = "nome do personagem"

[node name="ClassLabel" type="Label" parent="Root/Form"]
layout_mode = 2
text = "Classe"

[node name="Class" type="OptionButton" parent="Root/Form"]
layout_mode = 2

[node name="CharacterSelectLabel" type="Label" parent="Root/Form"]
layout_mode = 2
text = "Personagem (login)"

[node name="CharacterSelect" type="OptionButton" parent="Root/Form"]
layout_mode = 2

[node name="Login" type="Button" parent="Root/Form"]
layout_mode = 2
text = "Login"

[node name="Register" type="Button" parent="Root/Form"]
layout_mode = 2
text = "Registrar"

[node name="ConnectWorld" type="Button" parent="Root/Form"]
layout_mode = 2
disabled = true
text = "Conectar no Mundo"

[node name="OpenGame" type="Button" parent="Root/Form"]
layout_mode = 2
text = "Abrir Jogo"

[connection signal="pressed" from="Root/Form/Login" to="." method="_on_login_pressed"]
[connection signal="pressed" from="Root/Form/Register" to="." method="_on_register_pressed"]
[connection signal="pressed" from="Root/Form/ConnectWorld" to="." method="_on_connect_world_pressed"]
[connection signal="pressed" from="Root/Form/OpenGame" to="." method="_on_open_game_pressed"]
[connection signal="item_selected" from="Root/Form/CharacterSelect" to="." method="_on_character_select_item_selected"]
